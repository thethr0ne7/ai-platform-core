{
  "platform": "AI Platform Core",
  "version": "0.50.0",
  "components": {
    "core": "0.50.0",
    "web": "0.50.0",
    "schemas": "0.50.0",
    "runtime": "0.50.0"
  },
  "architecture": {
    "layers": [
      "product",
      "capability",
      "orchestration",
      "ingestion",
      "evidence",
      "learning",
      "data",
      "platform"
