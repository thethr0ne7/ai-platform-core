    "verticalSlice": "request -> planner -> capability resolution -> orchestration -> evidence -> result -> learning"
  },
  "qualityGates": [
    "strict-types",
    "workspace-build",
    "product-isolation",
    "capability-registration",
    "health-check",
    "no-secrets-in-repository",
    "replay-validation"
  ],
  "deployment": {
    "source": "GitHub",
    "frontend": "Vercel",
    "data": "Supabase",
    "aiRuntime": "Hugging Face compatible",
    "surfaces": [
      "web",
      "telegram-mini-app"
    ]
  }
}
