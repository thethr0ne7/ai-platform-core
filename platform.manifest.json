{
  "platform": "AI Platform Core",
  "version": "0.73.0",
  "codename": "Product Workspace UI",
  "components": {
    "core": "0.72.0",
    "web": "0.73.0",
    "schemas": "0.72.0",
    "runtime": "0.72.0",
    "governmentIntelligence": "0.72.0"
  },
  "architecture": {
    "layers": [
      "product",
      "government-data-plane",
      "evidence-and-truth",
      "government-intelligence",
      "orchestration",
      "learning",
      "platform"
    ],
    "verticalSlice": "project profile + documents -> parsing -> facts -> evidence -> eligibility -> truth gate -> decision cards -> application route -> controlled forecast",
    "epistemicContract": [
      "signal-is-not-fact",
      "trend-is-not-requirement",
      "forecast-is-not-eligibility",
      "narrative-is-not-legal-basis"
    ]
  },
  "productExperience": {
    "primaryJourney": [
      "project-profile",
      "documents-and-facts",
      "verified-result-and-route"
    ],
    "mobileFirst": true,
    "language": "ru",
    "technicalErrorsHiddenByDefault": true,
    "rawJsonInUserInterface": false
  },
  "qualityGates": [
    "strict-types",
    "workspace-build",
    "product-isolation",
    "capability-registration",
    "health-check",
    "no-secrets-in-repository",
    "replay-validation",
    "evidence-provenance",
    "truth-gated-decision-cards",
    "controlled-forecasting",
    "mobile-overflow",
    "human-readable-errors",
    "no-raw-json-ui"
  ],
  "deployment": {
    "source": "GitHub",
    "frontend": "Vercel",
    "data": "Supabase",
    "intelligenceStore": "Supabase PostgreSQL",
    "surfaces": [
      "web",
      "telegram-mini-app"
    ]
  },
  "legacy": {
    "repository": "thethr0ne7/ver436sia",
    "status": "REFERENCE_MIGRATION_SOURCE",
    "productionRuntime": false
  }
}
